---
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{jpg,jpeg,png,webp,avif,gif}',
  { eager: true }
);

function getProjectImages(slug: string): ImageMetadata[] {
  return Object.entries(imageModules)
    .filter(([path]) => path.startsWith(`/src/assets/images/${slug}/`))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([, mod]) => mod.default);
}

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props:  { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();

const projectImages = getProjectImages(project.slug);
const coverImage = projectImages[0] ?? null;

const dateStr = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  ogImage={coverImage?.src}
>
  <article class="project-detail">

    <!-- Image gallery (only shown when photos exist) -->
    {projectImages.length > 0 && (
      <div class="detail-gallery" id="detail-gallery">
        {projectImages.map((img, i) => (
          <div class:list={['gallery-slide', { active: i === 0 }]} data-index={i}>
            <img
              src={img.src}
              alt={`${project.data.title} — photo ${i + 1}`}
              class="gallery-img"
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding={i === 0 ? 'sync' : 'async'}
            />
          </div>
        ))}
        {projectImages.length > 1 && (
          <>
            <button class="gallery-prev" aria-label="Previous image">&#8249;</button>
            <button class="gallery-next" aria-label="Next image">&#8250;</button>
            <div class="gallery-counter">
              <span id="gallery-current">1</span> / {projectImages.length}
            </div>
          </>
        )}
      </div>
    )}

    <div class="container detail-body">

      <!-- Back link -->
      <a href="/portfolio" class="back-link">&larr; All projects</a>

      <div class="detail-layout">

        <!-- Main content -->
        <div class="detail-main">
          <span class="section-label">{project.data.category}</span>
          <h1>{project.data.title}</h1>
          <p class="detail-lead">{project.data.description}</p>
          <div class="divider"></div>
          <div class="prose">
            <Content />
          </div>
        </div>

        <!-- Sidebar specs -->
        <aside class="detail-sidebar">
          <div class="spec-card">
            <h2 class="spec-heading">Project Details</h2>
            <dl class="spec-list">
              <div class="spec-row">
                <dt>Date completed</dt>
                <dd>{dateStr}</dd>
              </div>
              {project.data.dimensions && (
                <div class="spec-row">
                  <dt>Dimensions</dt>
                  <dd>{project.data.dimensions}</dd>
                </div>
              )}
              {project.data.duration && (
                <div class="spec-row">
                  <dt>Build time</dt>
                  <dd>{project.data.duration}</dd>
                </div>
              )}
              {project.data.materials && project.data.materials.length > 0 && (
                <div class="spec-row">
                  <dt>Materials</dt>
                  <dd>
                    <ul class="materials-list">
                      {project.data.materials.map((m) => <li>{m}</li>)}
                    </ul>
                  </dd>
                </div>
              )}
            </dl>
            {project.data.available && (
              <a href="/contact" class="btn btn-primary" style="width:100%; justify-content:center; margin-top: var(--space-6);">
                Inquire about this piece
              </a>
            )}
          </div>
        </aside>

      </div>
    </div>
  </article>
</BaseLayout>

<style>
/* Gallery */
.detail-gallery {
  position: relative;
  width: 100%;
  height: 65vh;
  min-height: 300px;
  overflow: hidden;
  background: var(--color-black);
}

.gallery-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.6s ease;
}

.gallery-slide.active { opacity: 1; }

.gallery-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.gallery-prev,
.gallery-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--color-accent);
  font-size: 2.5rem;
  line-height: 1;
  padding: var(--space-3);
  transition: color var(--transition-fast), transform var(--transition-fast);
}

.gallery-prev { left: var(--space-4); }
.gallery-next { right: var(--space-4); }

.gallery-prev:hover {
  color: var(--color-black);
  transform: translateY(-50%) translateX(-3px);
}
.gallery-next:hover {
  color: var(--color-black);
  transform: translateY(-50%) translateX(3px);
}

.gallery-counter {
  position: absolute;
  bottom: var(--space-3);
  right: var(--space-5);
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 300;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 250, 0.65);
  pointer-events: none;
}

/* Body */
.detail-body {
  padding-block: var(--space-12);
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  margin-block-end: var(--space-8);
  transition: color var(--transition-fast);
}

.back-link:hover { color: var(--color-wood); }

/* Two-column layout */
.detail-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-12);
}

@media (min-width: 900px) {
  .detail-layout {
    grid-template-columns: 1fr 320px;
    align-items: start;
  }
}

/* Main */
.detail-lead {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: var(--leading-snug);
  max-width: 60ch;
  margin-block-end: 0;
}

/* Prose (rendered markdown) */
.prose {
  color: var(--color-text);
  line-height: var(--leading-normal);
}

.prose :global(h2) {
  font-size: var(--text-2xl);
  margin-block: var(--space-8) var(--space-4);
  color: var(--color-charcoal);
}

.prose :global(h3) {
  font-size: var(--text-xl);
  margin-block: var(--space-6) var(--space-3);
}

.prose :global(p) {
  margin-block-end: var(--space-5);
  max-width: var(--max-width-prose);
}

.prose :global(ul), .prose :global(ol) {
  padding-left: var(--space-6);
  margin-block-end: var(--space-5);
}

.prose :global(li) {
  margin-block-end: var(--space-2);
}

.prose :global(blockquote) {
  border-left: 4px solid var(--color-wood);
  padding-left: var(--space-6);
  color: var(--color-text-muted);
  font-style: italic;
  margin-block: var(--space-6);
}

/* Sidebar spec card */
.spec-card {
  background: var(--color-warm-white);
  border: 1px solid var(--color-border-dark);
  border-radius: var(--radius-md);
  padding: var(--space-6);
  box-shadow: var(--shadow-sm);
  position: sticky;
  top: calc(var(--header-height) + var(--space-6));
}

.spec-heading {
  font-size: var(--text-lg);
  font-weight: 600;
  margin-block-end: var(--space-5);
  padding-block-end: var(--space-4);
  border-bottom: 1px solid var(--color-border-dark);
}

.spec-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.spec-row {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.spec-row dt {
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.spec-row dd {
  font-size: var(--text-sm);
  color: var(--color-text);
  font-weight: 500;
}

.materials-list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.materials-list li::before {
  content: '— ';
  color: var(--color-wood);
}
</style>

<script>
(function () {
  const gallery = document.getElementById('detail-gallery');
  if (!gallery) return;

  const slides     = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-slide'));
  const counterEl  = document.getElementById('gallery-current');
  const prevBtn    = gallery.querySelector<HTMLButtonElement>('.gallery-prev');
  const nextBtn    = gallery.querySelector<HTMLButtonElement>('.gallery-next');

  if (slides.length < 2) return;

  let current = 0;

  function goTo(index: number) {
    slides[current].classList.remove('active');
    current = (index + slides.length) % slides.length;
    slides[current].classList.add('active');
    if (counterEl) counterEl.textContent = String(current + 1);
  }

  prevBtn?.addEventListener('click', () => goTo(current - 1));
  nextBtn?.addEventListener('click', () => goTo(current + 1));
})();
</script>
