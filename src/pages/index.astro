---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects');

// Auto-detect cover images from src/assets/images/{slug}/
// First file alphabetically in each folder = cover image.
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{jpg,jpeg,png,webp,avif,gif}',
  { eager: true }
);

function getHeroImage(slug: string, heroImage?: string): ImageMetadata | null {
  const entries = Object.entries(imageModules)
    .filter(([path]) => path.startsWith(`/src/assets/images/${slug}/`))
    .sort(([a], [b]) => a.localeCompare(b));
  if (heroImage) {
    const match = entries.find(([path]) => path.endsWith(`/${heroImage}`));
    if (match) return match[1].default;
  }
  return entries[0]?.[1]?.default ?? null;
}

// Hero shows only projects that have at least one photo, featured first
const sorted = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.date.getTime() - a.data.date.getTime();
});
const slides = sorted
  .map(p => ({ project: p, cover: getHeroImage(p.slug, p.data.heroImage) }))
  .filter((s): s is { project: typeof s.project; cover: ImageMetadata } => s.cover !== null);

const year = new Date().getFullYear();
---

<BaseLayout
  title="Oliver Tate Furniture"
  rawTitle={true}
  description="Oliver Tate Furniture — custom artisan furniture"
  heroLayout={true}
  hideFooter={true}
>

  <!-- ===================================================
       FULLSCREEN HERO SLIDESHOW
       =================================================== -->
  <section class="hero" aria-label="Portfolio highlights">

    <!-- Slides -->
    <div class="slides" id="slides">
      {slides.map(({ project, cover }, i) => (
        <a
          href={`/portfolio/#${project.slug}`}
          class:list={['slide', { active: i === 0 }]}
          data-index={i}
          tabindex={i === 0 ? '0' : '-1'}
          aria-label={`View ${project.data.title}`}
        >
          <Image
            src={cover}
            alt={project.data.coverAlt ?? project.data.title}
            class="slide-img"
            widths={[800, 1200, 1600, 2000]}
            sizes="100vw"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding={i === 0 ? 'sync' : 'async'}
          />
        </a>
      ))}
    </div>

    <!-- Dark gradient overlay for text legibility -->
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Wordmark -->
    <div class="hero-content" aria-hidden="true">
      <h1 class="hero-wordmark" aria-label="Oliver Tate Furniture">
        <img src="/logos/OT-Logo-black-bold.svg" alt="" class="wm-logo" aria-hidden="true" />
        <span class="wm-oliver" aria-hidden="true">liver</span>
        <span class="wm-furniture" aria-hidden="true">Furniture</span>
        <span class="wm-tate" aria-hidden="true">ate</span>
      </h1>
    </div>

    <!-- Bottom bar: current project title + slide indicators -->
    <div class="hero-bottom">
      <a
        href={`/portfolio/#${slides[0]?.project.slug ?? ''}`}
        class="hero-project-link"
        id="hero-project-link"
        aria-live="polite"
      >
        <span id="hero-project-title">{slides[0]?.project.data.title ?? ''}</span>
        <span class="hero-arrow" aria-hidden="true">→</span>
      </a>

      <div class="hero-indicators" role="tablist" aria-label="Slideshow navigation">
        {slides.map(({ project }, i) => (
          <button
            class:list={['indicator', { active: i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={`Slide ${i + 1}: ${project.data.title}`}
            data-index={i}
            data-slug={project.slug}
            data-title={project.data.title}
          ></button>
        ))}
      </div>
    </div>

    <!-- Next-slide chevron -->
    <button class="hero-next" aria-label="Next slide">&#8250;</button>

    <!-- Copyright overlay -->
    <div class="hero-copyright" aria-hidden="true">© {year} Oliver Tate Furniture</div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint-line"></span>
    </div>

  </section>


</BaseLayout>

<style>
/* ============================================================
   HERO
   ============================================================ */
.hero {
  position: relative;
  width: 100%;
  height: 100svh;       /* use svh so mobile browser chrome doesn't shrink it */
  min-height: 560px;
  overflow: hidden;
  background-color: var(--color-black);
}

/* ---- Slides ---- */
.slides {
  position: absolute;
  inset: 0;
}

.slide {
  position: absolute;
  inset: 0;
  display: block;
  opacity: 0;
  transition: opacity 1.2s ease;
  cursor: pointer;
  text-decoration: none;
}

.slide { pointer-events: none; }
.slide.active { opacity: 1; pointer-events: auto; }

/* Ken Burns: starts zoomed in, pans out to reveal full image */
@keyframes kenBurns {
  from { transform: scale(1.18); }
  to   { transform: scale(1);    }
}

.slide.active .slide-img {
  animation: kenBurns 7s ease-out forwards;
}

.slide-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  max-width: none;
  object-fit: cover;
  object-position: center;
}

/* ---- Overlay ---- */
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(79, 65, 51, 0.28) 0%,
    rgba(79, 65, 51, 0.08) 40%,
    rgba(79, 65, 51, 0.12) 70%,
    rgba(79, 65, 51, 0.55) 100%
  );
  pointer-events: none;
}

/* ---- Wordmark — top-left, slightly off-center from top ---- */
.hero-content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  pointer-events: none;
  padding-inline: clamp(var(--space-8), 8vw, 9rem);
  padding-top: 11vh;
  /* Soft white halo behind the wordmark, fades to edges */
  background: radial-gradient(ellipse 52% 32% at 18% 20%, rgba(255, 255, 250, 0.62) 0%, transparent 100%);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0);    }
}

.hero-wordmark {
  font-family: var(--font-logo);
  font-weight: 400;
  color: #000000;
  letter-spacing: 0.01em;
  animation: fadeUp 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;

  /* Font-size on the parent lets children use em units */
  font-size: clamp(2rem, 5vw, 4.5rem);

  /* Three-column grid: [logo] | [liver / ate] | [Furniture] */
  display: grid;
  grid-template-columns: max-content max-content max-content;
  grid-template-rows: auto auto;
  column-gap: 0;
  row-gap: 0;
  line-height: 1.05;
}

/* Logo spans both rows — sized to match 2 lines of text */
.wm-logo {
  grid-column: 1;
  grid-row: 1 / 3;
  height: 2.1em;   /* 2 lines × line-height 1.05 */
  width: auto;
  display: block;
  margin-top: -0.15em;  /* em scales with font-size at all breakpoints */
}

.wm-oliver {
  grid-column: 2;
  grid-row: 1;
  font-size: 1em;
  align-self: end;
  /*
   * Pull "liver" back toward the O's right edge.
   * SVG: O right edge at x=128 of 160 → 20% dead space = 0.32em of 1.6em image width.
   * Offset = 0.32em − 0.04em gap = −0.28em.
   */
  margin-left: -0.28em;
  margin-top: -0.14em;  /* em scales with font-size at all breakpoints */
}

.wm-tate {
  grid-column: 2;
  grid-row: 2;
  font-size: 1em;
  align-self: start;
  /*
   * Pull "ate" back toward the T stem (x=118 of 160 → 26% dead space = 0.42em).
   * Offset = 0.42em − 0.04em gap = −0.38em → also gives a small hanging indent vs "liver".
   */
  margin-left: -0.38em;
  margin-top: -0.42em;  /* em scales with font-size at all breakpoints */
}

.wm-furniture {
  grid-column: 3;
  grid-row: 1 / 3;     /* spans both rows, centered between them */
  align-self: end;
  font-size: clamp(1.5rem, 3.5vw, 3.2rem);
  letter-spacing: 0.06em;
  margin-bottom: 0.29em;  /* em scales with furniture's own font-size */
}

/* ---- Bottom bar ---- */
.hero-bottom {
  position: absolute;
  bottom: 0;
  inset-inline: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-6) var(--space-8);
  z-index: 2;
}

@media (max-width: 640px) {
  .hero-bottom {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
  }
}

/* Project title link */
.hero-project-link {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 255, 250, 0.7);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: var(--space-3);
  transition: color var(--transition-fast), gap var(--transition-base);
}

.hero-project-link:hover {
  color: var(--color-bg);
  gap: var(--space-4);
  opacity: 1;
}

.hero-arrow {
  display: inline-block;
  transition: transform var(--transition-base);
}

.hero-project-link:hover .hero-arrow {
  transform: translateX(4px);
}

/* Slide indicators */
.hero-indicators {
  display: flex;
  gap: var(--space-2);
  align-items: center;
}

.indicator {
  position: relative;
  width: 28px;
  height: 1px;
  background: rgba(255, 255, 250, 0.3);
  border: none;
  cursor: pointer;
  padding: 6px 0;       /* larger hit target */
  background-clip: content-box;
  transition: background-color var(--transition-fast);
}

.indicator::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--color-bg);
  transform: translateY(-50%);
}

/* Progress fill animation on active indicator */
@keyframes indicatorProgress {
  from { width: 0;    }
  to   { width: 100%; }
}

.indicator.active::after {
  animation: indicatorProgress 10s linear forwards;
}

/* ---- Scroll hint ---- */
.scroll-hint {
  position: absolute;
  bottom: var(--space-6);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
  /* Hide on mobile — bottom bar takes that space */
  display: none;
}

@keyframes scrollPulse {
  0%   { opacity: 0.4; transform: scaleY(0.3); transform-origin: top; }
  50%  { opacity: 1;   transform: scaleY(1);   transform-origin: top; }
  100% { opacity: 0;   transform: scaleY(1);   transform-origin: top; }
}

.scroll-hint-line {
  width: 1px;
  height: 40px;
  background: rgba(255, 255, 250, 0.5);
  animation: scrollPulse 2s ease-in-out infinite;
}

/* ---- Next-slide button ---- */
.hero-next {
  position: absolute;
  right: var(--space-6);
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--color-accent);
  font-size: 2.5rem;
  line-height: 1;
  padding: var(--space-3);
  transition: color var(--transition-fast), transform var(--transition-fast);
}

.hero-next:hover {
  color: var(--color-black);
  transform: translateY(-50%) translateX(3px);
}

/* ---- Copyright overlay ---- */
.hero-copyright {
  position: absolute;
  bottom: var(--space-4);
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 300;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 250, 0.45);
  white-space: nowrap;
  pointer-events: none;
}

/* ============================================================
   BELOW FOLD
   ============================================================ */
.intro {
  border-top: 1px solid var(--color-accent);
}

.intro-inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-10);
  align-items: flex-start;
  max-width: 800px;
}

.intro-text {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-xl), 2.5vw, var(--text-3xl));
  font-weight: 300;
  font-style: italic;
  line-height: var(--leading-snug);
  color: var(--color-black);
  max-width: 60ch;
}

.intro-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}
</style>

<script>
// ============================================================
//  HERO SLIDESHOW
// ============================================================
(function () {
  const slides      = Array.from(document.querySelectorAll<HTMLElement>('.slide'));
  const indicators  = Array.from(document.querySelectorAll<HTMLButtonElement>('.indicator'));
  const titleEl     = document.getElementById('hero-project-title');
  const linkEl      = document.getElementById('hero-project-link') as HTMLAnchorElement | null;

  if (!slides.length) return;

  let current = 0;
  let timer: ReturnType<typeof setTimeout>;
  const INTERVAL = 10000; // 7s pan + 3s pause

  const KB_ORIGINS = ['center', 'top left', 'top right', 'bottom left', 'bottom right'];

  function goTo(index: number) {
    slides[current].classList.remove('active');
    slides[current].setAttribute('tabindex', '-1');
    indicators[current]?.classList.remove('active');
    indicators[current]?.setAttribute('aria-selected', 'false');

    current = (index + slides.length) % slides.length;

    const img = slides[current].querySelector<HTMLElement>('.slide-img');
    if (img) {
      img.style.transformOrigin = KB_ORIGINS[Math.floor(Math.random() * KB_ORIGINS.length)];
    }

    slides[current].classList.add('active');
    slides[current].setAttribute('tabindex', '0');
    indicators[current]?.classList.add('active');
    indicators[current]?.setAttribute('aria-selected', 'true');

    const btn = indicators[current];
    if (btn && titleEl) titleEl.textContent = btn.dataset.title ?? '';
    if (btn && linkEl) linkEl.href = `/portfolio/#${btn.dataset.slug ?? ''}`;
  }

  function startTimer() {
    clearTimeout(timer);
    timer = setTimeout(() => {
      goTo(current + 1);
      startTimer();
    }, INTERVAL);
  }

  // Indicator clicks
  indicators.forEach((btn, i) => {
    btn.addEventListener('click', () => { goTo(i); startTimer(); });
  });

  // Next-slide chevron
  document.querySelector<HTMLButtonElement>('.hero-next')
    ?.addEventListener('click', () => { goTo(current + 1); startTimer(); });

  // Pause on hover — desktop only (touch devices fire mouseenter but never mouseleave,
  // which would permanently kill the timer)
  if (window.matchMedia('(hover: hover)').matches) {
    const hero = document.querySelector('.hero');
    hero?.addEventListener('mouseenter', () => clearTimeout(timer));
    hero?.addEventListener('mouseleave', startTimer);
  }

  // Start
  startTimer();
})();
</script>
