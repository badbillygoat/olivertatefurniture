---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** When true: header is fixed + transparent, overlays the hero */
  heroLayout?: boolean;
  /** When true: footer is hidden (used on home page) */
  hideFooter?: boolean;
  /** When true: use title as-is, without appending site name */
  rawTitle?: boolean;
}

const {
  title,
  description = 'Oliver Tate Furniture — bespoke furniture designs inspired by curves in nature, handcrafted in Cleveland, Ohio.',
  ogImage,
  heroLayout = false,
  hideFooter = false,
  rawTitle = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{rawTitle ? title : `${title} | Oliver Tate Furniture`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title"       content={`${title} | Oliver Tate Furniture`} />
    <meta property="og:description" content={description} />
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#4f4133" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B211BVRDTM"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-B211BVRDTM');
    </script>
  </head>

  <body class:list={[{ 'hero-page': heroLayout }]}>
    <Header transparent={heroLayout} />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    {!hideFooter && <Footer />}
  </body>
</html>
